# TradeCore Pro — Environment variables
#
# Copy this file to `.env` (or set these in your process manager / hosting
# platform's environment config) and fill in real values. Every variable
# marked "required" is checked at server boot by lib/env.ts — the server
# refuses to start at all if any are missing or malformed, listing every
# problem at once rather than failing on the first one hit.
#
# NEVER commit a real .env file. This is a template only.

# --- Server ------------------------------------------------------------------

# Required. Port the Express server listens on.
PORT=8080

# Optional. Address the server binds to. Leave UNSET to bind every interface
# (0.0.0.0) — correct for Replit and any platform that terminates TLS in front
# of the app. Set to 127.0.0.1 on a VPS where the dashboard is reached through
# an SSH tunnel or a local reverse proxy: the port then stays loopback-only and
# is never exposed on a public interface.
# HOST=127.0.0.1

# development | production | test. Affects: pino-pretty log formatting (dev
# only), Secure flag on the session cookie (production only, since it
# requires HTTPS), and the HSTS header (production only). Defaults to
# "development" if unset — but SESSION_SECRET becomes required if you set
# this to "production".
NODE_ENV=development

# --- Database ------------------------------------------------------------------

# Required. Postgres connection string.
DATABASE_URL=postgres://user:password@host:5432/tradecore

# --- Binance ------------------------------------------------------------------

# There is no global Binance API key/secret anymore — this is a multi-user
# app (Multi-user Phase). Each user registers their own account and enters
# their own Binance testnet/live API key + secret on the Settings page,
# encrypted at rest with CREDENTIALS_ENCRYPTION_KEY below. Each user's bot
# instance connects with their own credentials only.

# --- Authentication & credential encryption (Multi-user Phase) ---------------

# Required. AES-256-GCM key protecting every user's stored Binance API
# credentials — this is the one remaining server-side secret. Must be
# exactly 64 hex characters (32 bytes). Rotating this makes every previously
# stored credential undecryptable, so users would need to re-enter them.
# Generate with: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# Required in production (optional in development, where an insecure
# hardcoded fallback is used — never in production, this is enforced).
# Signs the session cookie POST /auth/login issues. Rotating this instantly
# invalidates every outstanding session for every user — a way to force a
# full logout everywhere.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Comma-separated list of additional origins allowed to make cross-origin,
# credentialed API requests (e.g. a separate Vite dev-server origin during
# local development, like http://localhost:5173). Leave empty in production
# — the frontend is served by this same Express app, so same-origin requests
# work with no entry needed here at all.
ALLOWED_ORIGINS=

# --- Social sign-in (Google / Apple) — OPTIONAL -------------------------------
#
# Each provider activates only when ALL of its variables are set; otherwise its
# button simply doesn't appear on the login page. Both require PUBLIC_URL.

# The exact origin users reach the app on (scheme + host + port, no trailing
# slash). Used to build the OAuth redirect URIs.
# PUBLIC_URL=https://your-domain.example:8443

# Google — free. Google Cloud Console → APIs & Services → Credentials →
# "OAuth client ID" (Web application). Add this authorized redirect URI:
#   <PUBLIC_URL>/api/auth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Apple — requires a paid Apple Developer Program membership. Create a
# Services ID with "Sign in with Apple", a Sign in with Apple key (.p8), and
# register this return URL:  <PUBLIC_URL>/api/auth/apple/callback
# APPLE_OAUTH_CLIENT_ID is the Services ID (e.g. com.example.tradecore.web);
# APPLE_OAUTH_PRIVATE_KEY is the .p8 file contents (newlines may be \n-escaped).
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=

# --- Deployment (VPS / update.sh) --------------------------------------------

# Optional, VPS only. Name of the PM2 process `update.sh` restarts after a
# build. It MUST match the app name in ecosystem.config.cjs — update.sh
# defaults to "tradecore", but this repo's ecosystem file declares
# "tradecore-api". Without this line update.sh builds the new code, fails to
# find the process, warns, and exits 0 — leaving the OLD build still running.
PM2_APP=tradecore-api

# Optional. Overrides PM2_APP entirely: the exact command update.sh runs to
# restart the service. Takes priority over PM2/systemd auto-detection.
# RESTART_CMD="pm2 restart tradecore-api"

# --- Logging ------------------------------------------------------------------

# Optional. pino log level. Defaults to "info".
LOG_LEVEL=info

# --- Ops monitoring -----------------------------------------------------------

# Optional. A Discord/Slack-compatible incoming webhook URL. When set, the
# process sends a compact alert here if it hits an uncaught exception or an
# unhandled promise rejection (in addition to always logging it), so you find
# out the trading process crashed without watching the logs. Leave unset to
# keep crash capture log-only. (Separate from the per-user risk-alert webhook
# configured in the app's Account & Safety page.)
OPS_ALERT_WEBHOOK_URL=

# Health endpoints (no config needed): GET /healthz = liveness (is it up),
# GET /readyz = readiness (can it reach the database — 200 ready / 503 not).
